# wshm-sandbox: Rootless Podman container for AI-powered code generation
# Used by `wshm fix --docker` to run Claude Code / Codex in isolation
#
# Build: podman build -f Dockerfile.sandbox -t wshm-sandbox:latest .
# Usage: wshm fix --issue 42 --docker --apply
#
# Credentials (priority order):
#   1. CLAUDE_CREDENTIALS_JSON env (CI: GitHub Secret) → mounted as ~/.claude/.credentials.json
#   2. ~/.claude/.credentials.json on host (local: OAuth/Max) → volume mount
#   3. ANTHROPIC_API_KEY env var (fallback: API key)

FROM node:22-slim

# Install git (required for Claude Code and Codex)
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install Claude Code CLI
RUN npm install -g @anthropic-ai/claude-code

# Install OpenAI Codex CLI (optional)
RUN npm install -g @openai/codex || true

# Create non-root user (matches --userns=keep-id:uid=1000,gid=1000)
RUN groupadd -g 1000 claude && \
    useradd -u 1000 -g claude -m -s /bin/bash claude

# Configure git for automated commits
RUN git config --global user.name "wshm[bot]" && \
    git config --global user.email "wshm[bot]@users.noreply.github.com" && \
    git config --global init.defaultBranch main

# Switch to non-root user
USER claude

# Working directory (mounted from host)
WORKDIR /workspace

ENTRYPOINT []
